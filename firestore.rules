rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: generations
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required) - The ID of the user who created this generation.
    //   - inputs: map (required) - The inputs used for generation.
    //   - outputs: map (required) - The generated outputs.
    //   - createdAt: timestamp (required) - The time the generation was created.
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function uidUnchanged() {
      return !('userId' in request.resource.data) || request.resource.data.userId == request.auth.uid;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidGeneration() {
      let data = request.resource.data;
      return hasOnlyAllowedFields(['userId', 'inputs', 'outputs', 'createdAt']) &&
             data.userId is string && data.userId.size() > 0 && data.userId.size() < 100 &&
             data.inputs is map &&
             data.outputs is map &&
             data.createdAt is timestamp;
    }

    match /generations/{generationId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() &&
                       isValidGeneration() &&
                       uidUnchanged() &&
                       request.resource.data.userId == request.auth.uid;
      allow update: if false; // Generations are immutable
      allow delete: if isDocOwner();
    }
  }
}
